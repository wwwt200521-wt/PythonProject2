# OpenAI-compatible LLM settings
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_MODEL=qwen/qwen3-vl-4b
OPENAI_API_KEY=local-key
OPENAI_MAX_TOKENS=8192

# AnythingLLM settings
ANYTHINGLLMAPIKEY=your-anythingllm-api-key
ANYTHINGLLM_BASE_URL=http://localhost:3001

# Tool orchestration settings
TOOL_CALL_MAX_ITERATIONS=8
FILESYSTEM_WORKSPACE_ONLY=true
TOOL_CALL_AUDIT_ENABLED=true
TOOL_CALL_AUDIT_LOG_PATH=runtime\tool_calls.jsonl
